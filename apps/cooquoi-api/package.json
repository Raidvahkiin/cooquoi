{
  "name": "@cooquoi/api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "bun run src/main.ts",
    "start:dev": "bun --watch src/main.ts",
    "start:debug": "bun --inspect src/main.ts",
    "start:prod": "node dist/main",
    "db:push": "DATABASE_URL=$(grep DATABASE_URL .env.local | cut -d= -f2-) drizzle-kit push --force",
    "db:generate": "DATABASE_URL=$(grep DATABASE_URL .env.local | cut -d= -f2-) drizzle-kit generate",
    "db:migrate": "DATABASE_URL=$(grep DATABASE_URL .env.local | cut -d= -f2-) drizzle-kit migrate",
    "db:studio": "DATABASE_URL=$(grep DATABASE_URL .env.local | cut -d= -f2-) drizzle-kit studio",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@cooquoi/market": "workspace:*",
    "@utils/nestjs": "workspace:*",
    "@nestjs/config": "^4.0.4",
    "@nestjs/platform-fastify": "^11.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "tsconfig-paths": "^4.2.0"
  }
}
