{
  "name": "@cooquoi/api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["type:app", "scope:consumer", "platform:nestjs"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config apps/cooquoi-api/vite.config.e2e.mts",
        "cwd": "{workspaceRoot}"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f apps/cooquoi-api/Dockerfile -t cooquoi-api:{args.tag} .",
        "cwd": "{workspaceRoot}"
      },
      "configurations": {
        "ci": {
          "command": "docker build -f apps/cooquoi-api/Dockerfile -t cooquoi-api:{args.tag} --no-cache ."
        }
      }
    }
  }
}
