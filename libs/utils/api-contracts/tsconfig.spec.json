{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist/vitest",
		"tsBuildInfoFile": "./dist/tsconfig.spec.tsbuildinfo",
		"types": [
			"vitest/globals",
			"vitest/importMeta",
			"vite/client",
			"node",
			"vitest"
		]
	},
	"include": [
		"vite.config.ts",
		"vite.config.mts",
		"vitest.config.ts",
		"vitest.config.mts",
		"**/*.ts",
		"**/*.test.ts",
		"**/*.spec.ts",
		"**/*.test.tsx",
		"**/*.spec.tsx",
		"**/*.test.js",
		"**/*.spec.js",
		"**/*.test.jsx",
		"**/*.spec.jsx",
		"**/*.d.ts"
	]
}